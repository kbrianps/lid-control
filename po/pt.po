msgid "Lid Control"
msgstr "Controle da Tampa"

msgid "Suspend"
msgstr "Suspender"

msgid "Do nothing"
msgstr "Não fazer nada"

msgid "Lock screen"
msgstr "Bloquear a tela"

msgid "Power off"
msgstr "Desligar"

msgid "Hibernate"
msgstr "Hibernar"

msgid "On battery"
msgstr "Na bateria"

msgid "Plugged in (AC power)"
msgstr "Na tomada (energia AC)"

msgid "Docked (external monitor or dock)"
msgstr "Em dock (monitor externo ou dock)"

msgid "What should happen when the lid is closed?"
msgstr "O que deve acontecer quando a tampa for fechada?"

msgid "Use the same action for all scenarios"
msgstr "Usar a mesma ação em todos os cenários"

msgid "Cancel"
msgstr "Cancelar"

msgid "Save"
msgstr "Salvar"

msgid "Menu"
msgstr "Menu"

msgid "Language"
msgstr "Idioma"

msgid "System default"
msgstr "Padrão do sistema"

msgid "About Lid Control"
msgstr "Sobre o Lid Control"

msgid "Configure what happens when the laptop lid is closed."
msgstr "Configure o que acontece quando a tampa do notebook é fechada."

msgid "Could not save the setting"
msgstr "Não foi possível salvar a configuração"

msgid ""
"The privileged helper returned an error. Try running `{path}` manually as "
"root to see what went wrong."
msgstr ""
"O ajudante privilegiado retornou um erro. Tente executar `{path}` "
"manualmente como root para ver o que deu errado."

msgid "pkexec not found"
msgstr "pkexec não encontrado"

msgid "Install policykit-1 (or polkit) to allow privileged writes."
msgstr "Instale policykit-1 (ou polkit) para permitir escritas privilegiadas."

msgid "Could not save language"
msgstr "Não foi possível salvar o idioma"

msgid "Language updated"
msgstr "Idioma atualizado"

msgid "The new language will be used the next time you open Lid Control."
msgstr "O novo idioma será usado na próxima vez que você abrir o Lid Control."

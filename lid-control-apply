#!/usr/bin/env python3
"""
lid-control-apply - privileged helper for Lid Control.

Writes /etc/systemd/logind.conf.d/lid-control.conf with the three
HandleLidSwitch* values and reloads systemd-logind.

Invoked via pkexec with three positional arguments (the action for
on-battery, plugged-in, and docked, in that order). Each must be one
of the whitelisted actions. The polkit policy at
/usr/share/polkit-1/actions/org.kbrianps.lid-control.policy lets the
active local user run this without a password.
"""

import os
import subprocess
import sys

CONF_DIR = "/etc/systemd/logind.conf.d"
CONF_FILE = f"{CONF_DIR}/lid-control.conf"
VALID_ACTIONS = {"suspend", "ignore", "lock", "poweroff", "hibernate"}


def main():
    if os.geteuid() != 0:
        print("lid-control-apply must run as root (via pkexec)", file=sys.stderr)
        return 2

    if len(sys.argv) != 4:
        print(
            "usage: lid-control-apply <on_battery> <on_ac> <docked>",
            file=sys.stderr,
        )
        return 2

    battery, ac, docked = sys.argv[1:4]
    for value in (battery, ac, docked):
        if value not in VALID_ACTIONS:
            print(f"invalid action: {value}", file=sys.stderr)
            return 2

    body = (
        "[Login]\n"
        f"HandleLidSwitch={battery}\n"
        f"HandleLidSwitchExternalPower={ac}\n"
        f"HandleLidSwitchDocked={docked}\n"
    )

    os.makedirs(CONF_DIR, exist_ok=True)
    with open(CONF_FILE, "w") as fp:
        fp.write(body)

    try:
        subprocess.run(
            ["systemctl", "reload", "systemd-logind"],
            check=True,
        )
    except subprocess.CalledProcessError as exc:
        print(f"systemctl reload systemd-logind failed: {exc}", file=sys.stderr)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())

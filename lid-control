#!/usr/bin/env python3
"""
Lid Control - configure systemd-logind HandleLidSwitch* via a GTK3 dialog.

Writes /etc/systemd/logind.conf.d/lid-control.conf and reloads logind.
"""

import os
import subprocess

import gi
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk

CONF_DIR = "/etc/systemd/logind.conf.d"
CONF_FILE = f"{CONF_DIR}/lid-control.conf"
ICON_PATH = "/usr/share/icons/hicolor/256x256/apps/lid-control.png"
HELPER_PATH = "/usr/libexec/lid-control-apply"

ACTIONS = [
    ("suspend",   "Suspend"),
    ("ignore",    "Do nothing"),
    ("lock",      "Lock screen"),
    ("poweroff",  "Power off"),
    ("hibernate", "Hibernate"),
]

SCENARIOS = [
    ("HandleLidSwitch",              "On battery"),
    ("HandleLidSwitchExternalPower", "Plugged in (AC power)"),
    ("HandleLidSwitchDocked",        "Docked (external monitor or dock)"),
]

DEFAULT_ACTION = "suspend"


def read_current():
    """Return {key: action} for the three HandleLidSwitch* keys, merged."""
    values = {key: DEFAULT_ACTION for key, _ in SCENARIOS}
    try:
        out = subprocess.check_output(
            ["systemd-analyze", "cat-config", "systemd/logind.conf"],
            text=True, stderr=subprocess.DEVNULL,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return values

    for line in out.splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, _, val = line.partition("=")
        key = key.strip()
        val = val.strip()
        if key in values and val:
            values[key] = val
    return values


class LidControlWindow(Gtk.Window):
    def __init__(self):
        super().__init__(title="Lid Control")
        # WMClass so the Ubuntu dock matches the .desktop launcher.
        # Deprecated in GTK3 but functional on X11; harmless on Wayland.
        try:
            self.set_wmclass("lid-control", "lid-control")
        except Exception:
            pass

        self.set_default_size(560, -1)
        self.set_resizable(False)
        self.set_position(Gtk.WindowPosition.CENTER)
        self.set_border_width(0)

        if os.path.isfile(ICON_PATH):
            try:
                self.set_icon_from_file(ICON_PATH)
            except Exception:
                pass

        current = read_current()
        self._suppress_mirror = False
        self.scenario_groups = {}   # key -> {action: Gtk.RadioButton}
        self.scenario_frames = {}   # key -> Gtk.Frame

        outer = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=12)
        outer.set_margin_top(16)
        outer.set_margin_bottom(16)
        outer.set_margin_start(16)
        outer.set_margin_end(16)
        self.add(outer)

        header = Gtk.Label()
        header.set_markup("<b>What should happen when the lid is closed?</b>")
        header.set_xalign(0)
        outer.pack_start(header, False, False, 0)

        self.apply_all_check = Gtk.CheckButton(
            label="Use the same action for all scenarios"
        )
        outer.pack_start(self.apply_all_check, False, False, 0)

        for key, label in SCENARIOS:
            frame = Gtk.Frame(label=f" {label} ")
            box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
            box.set_margin_top(8)
            box.set_margin_bottom(10)
            box.set_margin_start(12)
            box.set_margin_end(12)
            frame.add(box)
            outer.pack_start(frame, False, False, 0)

            group = {}
            first_radio = None
            current_action = current.get(key, DEFAULT_ACTION)
            for action, label_short in ACTIONS:
                radio = Gtk.RadioButton.new_with_label_from_widget(
                    first_radio, label_short
                )
                if first_radio is None:
                    first_radio = radio
                radio.set_active(action == current_action)
                radio.connect("toggled", self._on_radio_toggled, key, action)
                box.pack_start(radio, False, False, 0)
                group[action] = radio
            self.scenario_groups[key] = group
            self.scenario_frames[key] = frame

        # Checkbox starts checked if all three current values agree.
        all_equal = len({current[k] for k, _ in SCENARIOS}) == 1
        self.apply_all_check.set_active(all_equal)
        self.apply_all_check.connect("toggled", self._on_apply_all_toggled)
        self._sync_locked_state()

        # Buttons
        btn_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        btn_box.set_halign(Gtk.Align.END)
        btn_box.set_margin_top(4)

        cancel_btn = Gtk.Button(label="Cancel")
        cancel_btn.connect("clicked", lambda *_: self.close())
        btn_box.pack_start(cancel_btn, False, False, 0)

        save_btn = Gtk.Button(label="Save")
        save_btn.get_style_context().add_class("suggested-action")
        save_btn.connect("clicked", self._on_save)
        btn_box.pack_start(save_btn, False, False, 0)

        outer.pack_start(btn_box, False, False, 0)

    def _selected_action(self, key):
        for action, radio in self.scenario_groups[key].items():
            if radio.get_active():
                return action
        return DEFAULT_ACTION

    def _set_group_action(self, key, action):
        target = self.scenario_groups[key][action]
        if not target.get_active():
            target.set_active(True)

    def _on_radio_toggled(self, radio, key, action):
        if self._suppress_mirror or not radio.get_active():
            return
        if not self.apply_all_check.get_active():
            return
        if key != SCENARIOS[0][0]:
            return
        # Mirror the primary scenario to the other two.
        self._suppress_mirror = True
        try:
            for other_key, _ in SCENARIOS[1:]:
                self._set_group_action(other_key, action)
        finally:
            self._suppress_mirror = False

    def _on_apply_all_toggled(self, *_):
        self._sync_locked_state()
        if self.apply_all_check.get_active():
            primary = self._selected_action(SCENARIOS[0][0])
            self._suppress_mirror = True
            try:
                for other_key, _ in SCENARIOS[1:]:
                    self._set_group_action(other_key, primary)
            finally:
                self._suppress_mirror = False

    def _sync_locked_state(self):
        locked = self.apply_all_check.get_active()
        for other_key, _ in SCENARIOS[1:]:
            self.scenario_frames[other_key].set_sensitive(not locked)

    def _on_save(self, *_):
        values = {key: self._selected_action(key) for key, _ in SCENARIOS}
        battery = values["HandleLidSwitch"]
        ac      = values["HandleLidSwitchExternalPower"]
        docked  = values["HandleLidSwitchDocked"]

        # The privileged helper is allowed to run without a password thanks
        # to the polkit policy at
        # /usr/share/polkit-1/actions/org.kbrianps.lid-control.policy
        # (allow_active=yes for the active local session).
        try:
            subprocess.run(
                ["pkexec", HELPER_PATH, battery, ac, docked],
                check=True,
            )
        except subprocess.CalledProcessError:
            self._show_error(
                "Could not save the setting",
                "The privileged helper returned an error. Try running "
                f"`{HELPER_PATH}` manually as root to see what went wrong.",
            )
            return
        except FileNotFoundError:
            self._show_error(
                "pkexec not found",
                "Install policykit-1 (or polkit) to allow privileged writes.",
            )
            return

        self.close()

    def _show_error(self, primary, secondary):
        dialog = Gtk.MessageDialog(
            transient_for=self,
            modal=True,
            message_type=Gtk.MessageType.ERROR,
            buttons=Gtk.ButtonsType.OK,
            text=primary,
        )
        dialog.format_secondary_text(secondary)
        dialog.run()
        dialog.destroy()


def main():
    win = LidControlWindow()
    win.connect("destroy", Gtk.main_quit)
    win.show_all()
    Gtk.main()


if __name__ == "__main__":
    main()
